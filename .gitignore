# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out

# Dependency directories
# vendor/

# IDE files
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Build output
/bin/
/dist/

# Debug logs
logs/

# ---------------------------------------------------------------
# Credentials & configuration — NEVER commit these
# ---------------------------------------------------------------

# Environment files
.env
.env.*
*.env

# Auth0 tenant configs (contain client_id + client_secret)
config/
!config/.gitkeep

# Any YAML/JSON config that might hold secrets
*.secret.yaml
*.secret.yml
*.secret.json

# Key files
*.pem
*.key
*.p12
*.pfx
*.jks

# Auth0 specific
.auth0*

# Coverage
coverage.out
coverage.html